      "env": {
        "AWS_ACCESS_KEY_ID": "9",
        "AWS_SECRET_ACCESS_KEY": "9"
      },
      "configFiles": {
        "aws": "[default]\nsso_session = dev\n\n[sso-session dev]\nsso_region = us-west-2\nsso_start_url = https://some.url"
      },
      "ssoResponse": { "token": "aToken" }
    },
    "expected": {
      "resolved": { "token": "aToken" },
      "selectedProvider": "ProfileSsoSession"
    }
  },

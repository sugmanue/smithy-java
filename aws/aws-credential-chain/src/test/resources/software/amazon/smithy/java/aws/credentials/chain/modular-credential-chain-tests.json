          "terminal": true,
          "response": {
            "accessKeyId": "1",
            "secretAccessKey": "2",
            "sessionToken": "3",
            "accountId": "4"
          }
        }
      ]
    },
    "expected": {
      "resolved": {
        "accessKeyId": "1",
        "secretAccessKey": "2",
        "sessionToken": "3",
        "accountId": "4"
      },
      "selectedProvider": "CorporateVault"
    }
  },
  {

[
  {
    "id": "1",
    "documentation": "Modularity: only the core module is installed and env vars are set. ENVIRONMENT resolves; no STS/SSO/IMDS dependency is required.",
    "input": {
      "installedModules": ["core"],
      "env": {
        "AWS_ACCESS_KEY_ID": "1",
        "AWS_SECRET_ACCESS_KEY": "2",
        "AWS_SESSION_TOKEN": "3",
        "AWS_ACCOUNT_ID": "4"
      }
    },
    "expected": {
      "resolved": {
        "accessKeyId": "1",
        "secretAccessKey": "2",
        "sessionToken": "3",
        "accountId": "4"
      },
      "selectedProvider": "Environment",
      "featureIds": ["g"]
    }
  },
  {
    "id": "2",
    "documentation": "Terminal short-circuit: ENVIRONMENT is authoritative, so PROFILE_STATIC_KEYS is never assembled even though the profile has static keys.",
    "input": {
      "installedModules": ["core"],
      "env": {
        "AWS_ACCESS_KEY_ID": "1",
        "AWS_SECRET_ACCESS_KEY": "2"
      },
      "configFiles": {
        "aws": "[default]\naws_access_key_id = 9\naws_secret_access_key = 9"
      }
    },
    "expected": {
      "resolved": {
        "accessKeyId": "1",
        "secretAccessKey": "2",
        "sessionToken": null,
        "accountId": null
      },
      "selectedProvider": "Environment"
    }
  },
  {
    "id": "3",
    "documentation": "Terminal short-circuit is not backfilled when the authoritative source fails: the profile declares only assume-role and aws-credentials-sts is installed, so PROFILE_ASSUME_ROLE goes terminal at assembly and assembly stops. IMDS is installed with valid creds but was never registered, so when the STS call fails the chain returns that failure rather than falling back to IMDS.",
    "input": {
      "installedModules": [
        "core",
        "sts",
        "imds"
      ],
      "configFiles": {
        "aws": "[default]\nrole_arn = arn:aws:iam::123456789012:role/Foo\nsource_profile = A\n\n[profile A]\naws_access_key_id = 0\naws_secret_access_key = 0"
      },
      "stsResponse": { "error": "AccessDenied: not authorized to assume role" },
      "imdsResponse": {
        "accessKeyId": "8",
        "secretAccessKey": "8",
        "sessionToken": "8",
        "accountId": "8"
      }
    },
    "expected": {
      "resolutionError": {
        "providersTried": ["ProfileAssumeRole"],
        "moduleSuggestions": []
      }
    }
  },
  {
    "id": "4",
    "documentation": "Non-terminal fall-through: IMDS is non-terminal and fails, so a custom provider registered After(EC2_INSTANCE_METADATA) resolves.",
    "input": {
      "installedModules": ["core", "imds"],
      "customProviders": [
        {
          "name": "CustomFallback",
          "ordering": { "type": "After", "slot": "EC2_INSTANCE_METADATA" },
          "present": true,
          "terminal": true,
          "response": {
            "accessKeyId": "1",
            "secretAccessKey": "2",
            "sessionToken": "3",
            "accountId": "4"
          }
        }
      ],
      "imdsResponse": { "error": "IMDS returned 404" }
    },
    "expected": {
      "resolved": {
        "accessKeyId": "1",
        "secretAccessKey": "2",
        "sessionToken": "3",
        "accountId": "4"
      },
      "selectedProvider": "CustomFallback",
      "assembledOrder": ["Ec2InstanceMetadata", "CustomFallback"]
    }
  },
  {
    "id": "5",
    "documentation": "IMDS resolves when it is the only source and the module is installed. Confirms the non-terminal last-resort slot still works standalone.",

  {
    "id": "30",
    "documentation": "Full precedence walk with every module installed: env, profile assume-role, sso, ecs, and imds are all resolvable, but ENVIRONMENT is highest-priority and terminal, so it wins and downstream slots are never assembled.",
    "input": {
      "installedModules": [
        "core",
        "sts",
        "sso",
        "ecs",
        "imds"
      ],
      "env": {
        "AWS_ACCESS_KEY_ID": "1",
        "AWS_SECRET_ACCESS_KEY": "2",
        "AWS_SESSION_TOKEN": "3",
        "AWS_ACCOUNT_ID": "4",
        "AWS_CONTAINER_CREDENTIALS_FULL_URI": "https://169.254.170.2/creds"

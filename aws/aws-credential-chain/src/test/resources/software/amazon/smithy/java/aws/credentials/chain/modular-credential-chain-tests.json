  {
    "id": "12",
    "documentation": "Ordering, Before a claimed slot: a custom provider Before(ENVIRONMENT) is assembled ahead of ENVIRONMENT and wins when both would resolve.",
    "input": {
      "installedModules": ["core"],
      "customProviders": [
        {
          "name": "CorporateVault",
          "ordering": { "type": "Before", "slot": "ENVIRONMENT" },
          "present": true,
          "terminal": true,
          "response": {
            "accessKeyId": "1",
            "secretAccessKey": "2",
            "sessionToken": "3",
            "accountId": "4"
          }
        }
      ],
      "env": {
        "AWS_ACCESS_KEY_ID": "9",
        "AWS_SECRET_ACCESS_KEY": "9"
      }
    },
    "expected": {
      "resolved": {
        "accessKeyId": "1",
        "secretAccessKey": "2",
        "sessionToken": "3",
        "accountId": "4"
      },
      "selectedProvider": "CorporateVault"
    }
  },
  {
    "id": "13",
    "documentation": "Ordering, After a claimed slot: a custom provider After(ENVIRONMENT) is assembled behind ENVIRONMENT. ENVIRONMENT is absent (falls through), so the custom provider resolves.",
    "input": {
      "installedModules": ["core"],
      "customProviders": [
        {
          "name": "CorporateVault",
          "ordering": { "type": "After", "slot": "ENVIRONMENT" },

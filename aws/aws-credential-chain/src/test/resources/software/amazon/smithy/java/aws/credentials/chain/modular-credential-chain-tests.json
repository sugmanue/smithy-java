  {
    "id": "20",
    "documentation": "Unrecoverable resolver exception stops the chain immediately: a circular source_profile is detected while assuming a role. The chain surfaces the exception and does not fall through to IMDS.",
    "input": {
      "installedModules": [
        "core",
        "sts",
        "imds"
      ],
      "configFiles": {
        "aws": "[default]\nrole_arn = arn:aws:iam::123456789012:role/Foo\nsource_profile = default"
      },
      "stsResponse": {
        "error": "Circular source_profile reference: default -> default"
      },
      "imdsResponse": {
        "accessKeyId": "8",
        "secretAccessKey": "8",
        "sessionToken": "8",
        "accountId": "8"
      }
    },
    "expected": {
      "resolutionError": {
        "providersTried": ["ProfileAssumeRole"],
        "moduleSuggestions": []
      }
    }
  },
  {

<FindBugsFilter>
    <!-- Ignore all test files. -->
    <Match>
        <Class name="~Test\.java$"/>
    </Match>

    <!--  This is copy of Log4j's formatter.  -->
    <Match>
        <Class name="software.amazon.smithy.java.logging.ParameterFormatter$StringBuilders"/>
    </Match>

    <!-- Excessive Defensive copies. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Excessive Defensive checks on constructor exceptions. -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!-- Generated Recursive shapes will trigger this, although they will correctly instantiate -->
    <Match>
        <Source name="~.*build.*.java"/>
        <Bug pattern="IC_INIT_CIRCULARITY"/>
    </Match>

    <!--
    ~ Generated Resources will trigger this, although they do not actually leak internal implementation.
    ~ The root issue is that the `put()` method is considered suspicious, marking resource as mutable for spotbugs
    ~ See: https://github.com/spotbugs/spotbugs/issues/1797
    -->
    <Match>
        <Source name="~.*build.*.java"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>

    <!-- This warning cannot be suppressed per class for some reason, and it's also excessive. -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
    </Match>

    <Match>
        <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS"/>
        <Class name="software.amazon.smithy.java.dynamicschemas.SchemaGuidedDocumentBuilder$SchemaList"/>
    </Match>

    <Match>
        <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS"/>
        <Class name="software.amazon.smithy.java.dynamicschemas.SchemaGuidedDocumentBuilder$SchemaMap"/>
    </Match>

    <Match>
        <Class name="software.amazon.smithy.java.core.serde.document.Documents$LazyStructure">
            <Method name="equals">
                <Bug pattern="HE_EQUALS_USE_HASHCODE"/>
            </Method>
        </Class>
    </Match>

    <Match>
        <Class name="software.amazon.smithy.java.client.core.ClientCall$Builder">
            <Field name="executor">
                <Bug pattern="UWF_UNWRITTEN_FIELD"/>
            </Field>
        </Class>
    </Match>

    <Match>
        <Class name="software.amazon.smithy.java.rulesengine.BytecodeEvaluator" />
        <Bug pattern="RC_REF_COMPARISON_BAD_PRACTICE_BOOLEAN" />
    </Match>

    <Match>
        <Class name="software.amazon.smithy.java.rulesengine.BytecodeEvaluator" />
        <Bug pattern="DCN_NULLPOINTER_EXCEPTION" />
    </Match>

    <!--
    ~ signal() intentionally calls notifyAll() with no state change of its own: the queue state was
    ~ already mutated under the same monitor by a preceding burst of offer(..., signal=false) calls,
    ~ and signal() just flushes the deferred consumer wake. The naked-notify heuristic can't see the
    ~ prior offers, so this is a false positive.
    -->
    <Match>
        <Class name="software.amazon.smithy.java.http.client.h2.H2StreamBody"/>
        <Method name="signal"/>
        <Bug pattern="NN_NAKED_NOTIFY"/>
    </Match>

    <!-- JMH benchmark files - not production code -->
    <Match>
        <Class name="~.*\.http\.client\.VirtualThreadScalingBenchmark.*"/>
    </Match>

    <!--
    ~ http-client JMH benchmark harness (src/jmh) - not production code:
    ~ - @AuxCounters Counter fields are written by the benchmark and read reflectively by JMH (UrF).
    ~ - Shared payload constants are intentionally public so benchmarks in sibling packages reuse them (MS).
    ~ - Benchmark teardown intentionally ignores close() errors (DE).
    -->
    <Match>
        <Class name="~software\.amazon\.smithy\.java\.http\.client\..*Benchmark(\$.*)?"/>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD,UUF_UNUSED_PUBLIC_OR_PROTECTED_FIELD,MS_MUTABLE_ARRAY,MS_PKGPROTECT,MS_CANNOT_BE_FINAL"/>
    </Match>
    <Match>
        <Class name="software.amazon.smithy.java.http.client.BenchmarkSupport"/>
        <Bug pattern="MS_MUTABLE_ARRAY,MS_PKGPROTECT,MS_CANNOT_BE_FINAL"/>
    </Match>
    <Match>
        <Class name="~software\.amazon\.smithy\.java\.http\.client\.h2\.(EventLoopH2cTransport|ConnectionAgentH2cTransport|EventLoopH2Transport)"/>
        <Bug pattern="DE_MIGHT_IGNORE"/>
    </Match>

    <!-- JMH reads @AuxCounters fields reflectively to report them as auxiliary counters. -->
    <Match>
        <Class name="software.amazon.smithy.java.aws.client.rulesengine.S3EndpointBenchmark$BytecodeMetrics" />
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD" />
    </Match>

    <!-- Atomicity warnings introduced by SpotBugs 6.5+ upgrade — suppress globally until code is audited. -->
    <Match>
        <Bug pattern="AT_STALE_THREAD_WRITE_OF_PRIMITIVE"/>
    </Match>
    <Match>
        <Bug pattern="AT_NONATOMIC_OPERATIONS_ON_SHARED_VARIABLE"/>
    </Match>
    <Match>
        <Bug pattern="AT_NONATOMIC_64BIT_PRIMITIVE"/>
    </Match>

    <!-- Unnecessary suppression warnings introduced by SpotBugs 6.5+ upgrade. -->
    <Match>
        <Bug pattern="US_USELESS_SUPPRESSION_ON_METHOD"/>
    </Match>
    <Match>
        <Bug pattern="US_USELESS_SUPPRESSION_ON_CLASS"/>
    </Match>
    <Match>
        <Bug pattern="US_USELESS_SUPPRESSION_ON_FIELD"/>
    </Match>

    <!-- Vendored Schubfach algorithm (from Jackson/OpenJDK) — not our code to fix. -->
    <Match>
        <Class name="software.amazon.smithy.java.codecs.commons.Schubfach$DoubleToDecimal" />
    </Match>
    <Match>
        <Class name="software.amazon.smithy.java.codecs.commons.Schubfach$FloatToDecimal" />
    </Match>

    <!--
    ~ Intentional String reference (==) fast path before the equals() comparison. Header names are
    ~ canonicalized to interned constants, so a reference hit is a cheap shortcut; every == check is
    ~ paired with an equals()/regionMatches() fallback, so correctness never depends on it.
    -->
    <Match>
        <Class name="software.amazon.smithy.java.http.api.HeaderName"/>
        <Method name="canonicalize"/>
        <Bug pattern="ES_COMPARING_PARAMETER_STRING_WITH_EQ"/>
    </Match>
    <Match>
        <Class name="software.amazon.smithy.java.http.api.ArrayHttpHeaders"/>
        <Method name="setHeaderCanonical"/>
        <Bug pattern="ES_COMPARING_PARAMETER_STRING_WITH_EQ"/>
    </Match>

    <Match>
        <Class name="~software\.amazon\.smithy\.java\.mcp\.server\.ProtocolVersion\$.*"/>
        <Bug pattern="EQ_COMPARETO_USE_OBJECT_EQUALS"/>
    </Match>

</FindBugsFilter>
